        "Text": {
          "type": "cexolocstring",
          "value": {
            "0": "GSI does not usually hire freelancers for field extermination. We prefer data, samples, and controlled recovery teams. But what came across my desk was... not something I intend to send interns after."
          }
        }
      },
      {
        "__struct_id": 1,
        "ActionParams": {
