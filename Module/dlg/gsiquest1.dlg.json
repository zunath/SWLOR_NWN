        },
        "Speaker": {
          "type": "cexostring",
          "value": ""
        },
        "Text": {
          "type": "cexolocstring",
          "value": {
            "0": "Then came the last report. One of the station's old survey archives referenced a transported specimen Arkanian origin, classified, never properly logged into Republic channels. Large. Aggressive. Extremely resilient"
          }
        }
      },
      {
        "__struct_id": 3,
        "ActionParams": {
          "type": "list",
          "value": []
        },
        "Animation": {
          "type": "dword",
          "value": 0
