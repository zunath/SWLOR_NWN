        "Speaker": {
          "type": "cexostring",
          "value": ""
        },
        "Text": {
          "type": "cexolocstring",
          "value": {
            "0": "Board the abandoned station. Confirm the report. Kill the beast. Then bring back proof so I can close this file with something more useful than rumor and bloodstains."
          }
        }
      },
      {
        "__struct_id": 5,
        "ActionParams": {
          "type": "list",
          "value": []
        },
        "Animation": {
          "type": "dword",
