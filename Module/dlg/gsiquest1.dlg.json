        "Speaker": {
          "type": "cexostring",
          "value": ""
        },
        "Text": {
          "type": "cexolocstring",
          "value": {
            "0": "A maintenance relay in an abandoned station outside the Nar Shaddaa lanes began transmitting again. At first we assumed squatters or scavengers. Then we received fragmented logs. Torn bulkheads. Missing crews. Heat signatures too large for any known pest species aboard station infrastructure. "
          }
        }
      },
      {
        "__struct_id": 2,
        "ActionParams": {
          "type": "list",
          "value": []
        },
        "Animation": {
          "type": "dword",
          "value": 0
